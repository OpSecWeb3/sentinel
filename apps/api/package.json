{
  "name": "@sentinel/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@sentinel/db": "workspace:*",
    "@sentinel/module-aws": "workspace:*",
    "@sentinel/module-chain": "workspace:*",
    "@sentinel/module-github": "workspace:*",
    "@sentinel/module-infra": "workspace:*",
    "@sentinel/module-registry": "workspace:*",
    "@sentinel/notifications": "workspace:*",
    "@sentinel/shared": "workspace:*",
    "argon2": "^0.44.0",
    "hono": "^4.12.12",
    "ioredis": "^5.4.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "postgres": "^3.4.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
