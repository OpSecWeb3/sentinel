{
  "name": "sentinel",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "docker compose -f docker-compose.dev.yml up",
    "dev:build": "docker compose -f docker-compose.dev.yml up --build",
    "dev:down": "docker compose -f docker-compose.dev.yml down",
    "dev:infra": "docker compose -f docker-compose.dev.yml up postgres redis",
    "dev:api": "pnpm --filter @sentinel/api dev",
    "dev:worker": "pnpm --filter @sentinel/worker dev",
    "dev:web": "pnpm --filter @sentinel/web dev",
    "build": "pnpm -r build",
    "db:generate": "pnpm --filter @sentinel/db generate",
    "db:migrate": "pnpm --filter @sentinel/db migrate",
    "db:seed": "pnpm --filter @sentinel/db seed",
    "db:studio": "pnpm --filter @sentinel/db studio",
    "test": "vitest run",
    "test:docker": "docker compose -f docker-compose.dev.yml --profile test run --rm test",
    "test:unit": "vitest run packages/ modules/",
    "test:integration": "vitest run apps/ test/",
    "test:watch": "vitest watch",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.0",
    "ioredis": "^5.4.2",
    "postgres": "^3.4.5",
    "prom-client": "^15.1.3",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
